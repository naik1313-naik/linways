---
const projects = [
  {
    title: '3D Product Explorer',
    description: 'Interactive configurator with real-time rendering and smooth storytelling transitions.',
    link: '#',
  },
  {
    title: 'Analytics Command Center',
    description: 'High-performance dashboard featuring dynamic charts, role-based views, and live updates.',
    link: '#',
  },
  {
    title: 'Immersive Learning Hub',
    description: 'Modern educational platform with micro-animations and adaptive content delivery.',
    link: '#',
  },
];
---

<section id="projects" class="mx-auto w-[min(92%,1100px)] py-24">
  <div class="mb-10">
    <p class="mb-3 text-sm uppercase tracking-[0.35em] text-cyan-300">Projects</p>
    <h2 class="section-title">Selected work</h2>
  </div>
  <div class="grid gap-6 md:grid-cols-3">
    {projects.map((project) => (
      <article class="project-card glass group rounded-3xl p-6 transition duration-500 hover:-translate-y-2 hover:shadow-glow">
        <h3 class="text-xl font-semibold">{project.title}</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/70">{project.description}</p>
        <a href={project.link} class="mt-5 inline-flex text-sm font-semibold text-cyan-300 transition hover:text-cyan-200">
          View project →
        </a>
      </article>
    ))}
  </div>
</section>
