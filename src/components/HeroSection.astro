---
import HeroScene from './HeroScene';
---

<section id="hero" class="relative flex min-h-screen items-center overflow-hidden bg-hero-gradient">
  <div class="absolute inset-0 opacity-95">
    <HeroScene client:only="react" />
  </div>
  <div class="pointer-events-none relative z-10 mx-auto w-[min(92%,1100px)] py-24">
    <div class="glass max-w-2xl rounded-3xl p-8 md:p-12">
      <p class="hero-subtitle mb-4 text-sm uppercase tracking-[0.4em] text-cyan-300">3D Portfolio</p>
      <h1 class="hero-title text-4xl font-bold leading-tight md:text-7xl">
        Building immersive web experiences with modern tools.
      </h1>
      <p class="hero-copy mt-4 max-w-xl text-base text-white/75 md:text-lg">
        Astro + React + Three.js portfolio with smooth GSAP motion, interactive 3D visuals, and premium glassmorphism design.
      </p>
    </div>
  </div>
</section>
