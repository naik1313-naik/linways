<section id="contact" class="mx-auto w-[min(92%,1100px)] py-24">
  <div class="glass rounded-3xl p-8 md:p-12">
    <p class="mb-3 text-sm uppercase tracking-[0.35em] text-cyan-300">Contact</p>
    <h2 class="section-title">Let's create something exceptional</h2>
    <form class="mt-8 grid gap-4 md:grid-cols-2">
      <label class="md:col-span-1">
        <span class="mb-2 block text-sm text-white/80">Name</span>
        <input class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3 outline-none transition focus:border-cyan-300" placeholder="Jane Doe" />
      </label>
      <label class="md:col-span-1">
        <span class="mb-2 block text-sm text-white/80">Email</span>
        <input type="email" class="w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3 outline-none transition focus:border-cyan-300" placeholder="jane@example.com" />
      </label>
      <label class="md:col-span-2">
        <span class="mb-2 block text-sm text-white/80">Message</span>
        <textarea class="min-h-32 w-full rounded-xl border border-white/15 bg-white/5 px-4 py-3 outline-none transition focus:border-cyan-300" placeholder="Tell me about your project"></textarea>
      </label>
      <div class="md:col-span-2">
        <button type="button" class="rounded-xl bg-gradient-to-r from-violet-500 to-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:opacity-90">
          Send message
        </button>
      </div>
    </form>
  </div>
</section>
