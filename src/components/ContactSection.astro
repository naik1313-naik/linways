<section id="contact" class="section-container py-24">
  <div class="glass-panel rounded-3xl p-8 md:p-10">
    <p class="mb-4 text-sm uppercase tracking-[0.2em] text-cyan-300">Contact</p>
    <h2 class="mb-6 text-3xl font-semibold text-white md:text-4xl">Let’s build something exceptional</h2>
    <form class="grid gap-4 md:grid-cols-2">
      <label class="block text-sm text-slate-200 md:col-span-1">
        Name
        <input class="mt-2 w-full rounded-xl border border-slate-700 bg-slate-950/50 px-4 py-3 outline-none transition focus:border-cyan-300" placeholder="Jane Doe" />
      </label>
      <label class="block text-sm text-slate-200 md:col-span-1">
        Email
        <input type="email" class="mt-2 w-full rounded-xl border border-slate-700 bg-slate-950/50 px-4 py-3 outline-none transition focus:border-cyan-300" placeholder="jane@company.com" />
      </label>
      <label class="block text-sm text-slate-200 md:col-span-2">
        Message
        <textarea class="mt-2 h-32 w-full rounded-xl border border-slate-700 bg-slate-950/50 px-4 py-3 outline-none transition focus:border-cyan-300" placeholder="Tell me about your project"></textarea>
      </label>
      <button type="submit" class="w-fit rounded-xl bg-gradient-to-r from-cyan-400 to-violet-500 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:opacity-90">
        Send message
      </button>
    </form>
  </div>
</section>
