---
const links = [
  { label: 'About', href: '#about' },
  { label: 'Projects', href: '#projects' },
  { label: 'Kudos', href: '#kudos' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="glass sticky top-4 z-50 mx-auto mt-4 w-[min(92%,980px)] rounded-full px-4 py-3 shadow-glow">
  <div class="flex items-center justify-between gap-4">
    <a href="#hero" class="text-sm font-semibold tracking-[0.2em] text-cyan-300">LINWAYS</a>
    <ul class="flex flex-wrap items-center justify-end gap-3 text-sm md:gap-6">
      {links.map((link) => (
        <li>
          <a href={link.href} class="rounded-full px-3 py-1.5 text-white/80 transition hover:bg-white/10 hover:text-white">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
