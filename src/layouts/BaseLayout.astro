---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = '3D Portfolio' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="A premium 3D portfolio built with Astro, React, Three.js and GSAP." />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
